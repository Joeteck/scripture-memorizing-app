# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bible API (bolls.life - free, no key needed)
EXPO_PUBLIC_BIBLE_API_BASE=https://bolls.life

# Sentry crash/error reporting (optional but recommended before release).
# Create a free project at https://sentry.io, then paste its DSN below.
# Leave blank to disable — src/lib/monitoring.ts no-ops without it.
EXPO_PUBLIC_SENTRY_DSN=

# SECURITY NOTES:
# - NEVER commit .env to git. It is already in .gitignore.
# - The ANON key is safe to expose in a React Native app (Supabase RLS protects data).
# - Enable RLS on ALL tables (see supabase/schema.sql).
# - Never use the SERVICE_ROLE key in the app — only in server-side scripts.
